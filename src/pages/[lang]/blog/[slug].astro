---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, type Language, defaultLanguage } from '../../../i18n/utils';
import { blogPosts } from '../../../content/blog-posts';

export function getStaticPaths() {
  return Object.keys(blogPosts).flatMap(slug => [
    { params: { lang: 'en', slug } },
    { params: { lang: 'cz', slug } },
  ]);
}

interface Props {
  params: {
    lang: Language;
    slug: string;
  };
}

const { lang = defaultLanguage, slug = '' } = Astro.params as Props['params'];
const t = useTranslations(lang as Language);
const post = blogPosts[slug];

if (!post) {
  return Astro.redirect(`/${lang}/blog`);
}
---

<BaseLayout title={post.title} lang={lang as Language}>
  <article class="blog-post">
    <header class="post-header">
      <h1>{post.title}</h1>
      <p class="date">{post.date}</p>
      <p class="reading-time">5 min read</p>
    </header>

    <Fragment set:html={post.content} />

    <div class="post-footer">
      <a href={`/${lang}/blog`} class="back-link">{t('backToArticles')}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .post-header h1 {
    margin-bottom: 1rem;
  }

  .date {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .reading-time {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  :global(.post-content) {
    line-height: 1.8;
  }

  :global(.post-content p) {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  :global(.post-content h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  :global(.post-content ul) {
    list-style: disc;
    margin-left: 2rem;
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
  }

  :global(.post-content li) {
    margin-bottom: 0.5rem;
  }

  :global(.post-content blockquote) {
    margin: 2rem 0;
    padding-left: 1.5rem;
    border-left: 4px solid var(--accent);
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    color: var(--accent);
  }

  .back-link:hover {
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .blog-post {
      padding: 0;
    }
  }
</style>
