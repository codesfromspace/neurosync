---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>NeuroSync</h1>
    <p class="tagline">Exploring the intersection of psychiatry and artificial intelligence</p>
    <p class="subtitle">
      Psychiatrist & AI researcher exploring clinical applications of machine learning,
      digital therapeutics, and the future of mental healthcare.
    </p>
    <div class="cta-buttons">
      <a href="/neurosync/about" class="btn btn-primary">Learn More</a>
      <a href="/neurosync/blog" class="btn btn-secondary">Read Articles</a>
    </div>
  </section>

  <section class="featured" id="featured">
    <h2>Featured Research Areas</h2>
    <div class="cards">
      <div class="card">
        <h3>🧠 Clinical AI</h3>
        <p>Machine learning applications in psychiatric diagnosis and treatment planning</p>
      </div>
      <div class="card">
        <h3>⚕️ Digital Therapeutics</h3>
        <p>Evidence-based digital interventions and their clinical outcomes</p>
      </div>
      <div class="card">
        <h3>🔬 Research & Innovation</h3>
        <p>Exploring cutting-edge developments in neurotechnology and data science</p>
      </div>
    </div>
  </section>

  <section class="latest-posts" id="latest">
    <h2>Latest Articles</h2>
    <div class="posts-preview">
      <article class="post-card">
        <h3><a href="/neurosync/blog/ai-psychiatry-future">The Future of AI in Psychiatry</a></h3>
        <p class="meta">May 10, 2026</p>
        <p>Exploring how machine learning is reshaping diagnostic and therapeutic approaches...</p>
        <a href="/neurosync/blog/ai-psychiatry-future" class="read-more">Read more →</a>
      </article>
      <article class="post-card">
        <h3><a href="/neurosync/blog/ethics-mental-health-ai">Ethics in Mental Health AI</a></h3>
        <p class="meta">April 28, 2026</p>
        <p>Critical considerations for developing trustworthy AI in clinical psychiatric settings...</p>
        <a href="/neurosync/blog/ethics-mental-health-ai" class="read-more">Read more →</a>
      </article>
    </div>
    <div class="view-all">
      <a href="/neurosync/blog">View all articles →</a>
    </div>
  </section>

  <section class="contact" id="contact">
    <h2>Get in Touch</h2>
    <p>Interested in collaboration, consultation, or just want to discuss the intersection of psychiatry and AI?</p>
    <a href="mailto:hello@neurosync.dev" class="btn btn-primary">Send Email</a>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    margin-bottom: 4rem;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--accent-light);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.8;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .btn {
    padding: 0.875rem 2rem;
    border-radius: 0.5rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--accent-light);
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .btn-secondary:hover {
    background: var(--accent);
    color: white;
  }

  .featured {
    margin-bottom: 4rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .card h3 {
    margin-bottom: 1rem;
    color: var(--accent-light);
  }

  .card p {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .latest-posts {
    margin-bottom: 4rem;
  }

  .posts-preview {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  .post-card {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }

  .post-card:hover {
    border-color: var(--accent);
  }

  .post-card h3 {
    margin-bottom: 0.5rem;
  }

  .post-card a {
    color: var(--accent-light);
  }

  .meta {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .post-card p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .read-more {
    color: var(--accent);
    font-weight: 500;
  }

  .view-all {
    text-align: center;
    margin-top: 2rem;
  }

  .view-all a {
    font-size: 1.1rem;
  }

  .contact {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg-secondary);
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    margin: 4rem 0;
  }

  .contact h2 {
    margin-bottom: 1rem;
  }

  .contact p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 0;
    }

    h1 {
      font-size: 2rem;
    }

    .cta-buttons {
      flex-direction: column;
    }
  }
</style>
