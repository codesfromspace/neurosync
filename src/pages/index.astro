---
// Root redirect to preferred language
const preferredLang = Astro.request.headers.get('accept-language')?.startsWith('cs') ? 'cz' : 'en';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=/${preferredLang}/`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href={`/${preferredLang}/`}>your language</a>...</p>
  </body>
</html>
